# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit real secrets.

# --- Staff sign-in (verifies a login email against the school staff API) ---
# Base URL of the staff directory API (no trailing slash).
STAFF_API_BASE=https://your-staff-api.example.com
# Bearer token with staff.read scope. Server-side only; never sent to the browser.
STAFF_API_TOKEN=CHANGE-ME

# Shared password every staff member enters alongside their email.
STAFF_PASSWORD=CHANGE-ME

# --- Session cookie signing ---
# Long random string used to sign the session token (HMAC-SHA256).
# Generate one with:  openssl rand -hex 32
SESSION_SECRET=CHANGE-ME

# How many hours a sign-in lasts (optional, default 12).
SESSION_HOURS=12
